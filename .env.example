# OpenRouter — daftar & ambil key di https://openrouter.ai/keys
# JANGAN commit file .env asli ke git (sudah di-ignore).
# Di Vercel: set variable ini di Project Settings > Environment Variables.
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opsional: ganti model. Default google/gemini-2.0-flash-001 (murah & cepat).
# Contoh lain: openai/gpt-4o-mini, anthropic/claude-3.5-haiku, meta-llama/llama-3.1-8b-instruct
OPENROUTER_MODEL=google/gemini-2.0-flash-001
